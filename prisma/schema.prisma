generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  dispatcher
  installer
  delivery_lead
}

enum TeamType {
  delivery
  installation
  hybrid
}

enum JobType {
  delivery
  installation
  service
  repair
}

enum JobStatus {
  new
  awaiting_shipment
  shipped
  ready_to_schedule
  scheduled
  dispatched
  on_site
  completed
  follow_up_required
  rescheduled
  cancelled
}

enum Division {
  construction
  hotshots
  sales
  trucking
}

enum CompanyType {
  internal
  subcontractor
  partner
}

enum MessageTargetScope {
  all_active_field
  role
  user
  work_order
  company
}

enum MessageCategory {
  general
  operations
  sop
  safety
  maintenance
  payroll_1099
}

enum WorkOrderItemStatus {
  pending
  completed
  skipped
}

model LocationPing {
  id          String   @id @default(uuid())
  userId      String
  workOrderId String
  latitude    Float
  longitude   Float
  accuracy    Float?
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([workOrderId])
  @@index([createdAt])
}

model User {
  id           String   @id @default(uuid())
  firstName    String
  lastName     String
  email        String   @unique
  passwordHash String
  role         UserRole
  isActive     Boolean  @default(true)
  companyId    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company                  Company?              @relation(fields: [companyId], references: [id], onDelete: SetNull)
  assignments              WorkOrderAssignment[]
  dispatchMessagesCreated  DispatchMessage[]     @relation("DispatchMessageCreatedBy")
  dispatchMessagesTargeted DispatchMessage[]     @relation("DispatchMessageTargetUser")
  dispatchMessageReads     DispatchMessageRead[]
  workOrderNotes           WorkOrderNote[]
  locationLogs             UserLocationLog[]
  locationPings            LocationPing[]
  teamMessages             TeamMessage[]

  @@index([companyId])
  @@index([role, isActive])
}

model Team {
  id        String    @id @default(uuid())
  name      String
  teamType  TeamType
  division  Division?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  assignments  WorkOrderAssignment[]
  teamMessages TeamMessage[]

  @@index([teamType, isActive])
  @@index([division, isActive])
}

model Company {
  id          String      @id @default(uuid())
  name        String
  companyType CompanyType
  division    Division?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  users            User[]
  targetedMessages DispatchMessage[] @relation("DispatchMessageTargetCompany")

  @@index([companyType, isActive])
  @@index([division, isActive])
}

model Customer {
  id        String   @id @default(uuid())
  fullName  String
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  addresses  Address[]
  workOrders WorkOrder[]
}

model Address {
  id          String   @id @default(uuid())
  customerId  String?
  line1       String
  line2       String?
  city        String
  state       String
  postalCode  String
  country     String
  accessNotes String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer   Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  workOrders WorkOrder[]
}

model WorkOrder {
  id                      String    @id @default(uuid())
  workOrderNumber         String    @unique
  customerReferenceNumber String?
  searchText              String?
  externalSource          String?
  externalId              String?
  customerId              String
  addressId               String
  jobType                 JobType
  division                Division  @default(construction)
  internalStatus          JobStatus
  priority                String    @default("normal")
  scheduledStartAt        DateTime?
  scheduledEndAt          DateTime?
  dispatcherNotes         String?
  accessNotes             String?
  isLocked                Boolean   @default(false)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  customer         Customer                 @relation(fields: [customerId], references: [id])
  address          Address                  @relation(fields: [addressId], references: [id])
  assignments      WorkOrderAssignment[]
  hotShotDetails   HotShotDetails?
  statusHistory    WorkOrderStatusHistory[]
  notes            WorkOrderNote[]
  media            WorkOrderMedia[]
  events           WorkOrderEvent[]
  items            WorkOrderItem[]
  dispatchMessages DispatchMessage[]
  locationPings    LocationPing[]

  @@index([division, internalStatus, scheduledStartAt])
  @@index([jobType, division])
  @@index([customerReferenceNumber])
  @@index([externalSource, externalId])
  @@index([isLocked])
}

model WorkOrderItem {
  id                String              @id @default(cuid())
  workOrderId       String
  title             String
  description       String?
  quantity          Int?
  sortOrder         Int                 @default(0)
  status            WorkOrderItemStatus @default(pending)
  isRequired        Boolean             @default(true)
  completedAt       DateTime?
  completedByUserId String?
  createdByUserId   String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([workOrderId, sortOrder])
  @@index([workOrderId, status])
}

model WorkOrderNote {
  id              String   @id @default(uuid())
  workOrderId     String
  noteType        String
  body            String
  createdByUserId String?
  createdAt       DateTime @default(now())

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  createdBy User?     @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([workOrderId, createdAt])
  @@index([createdByUserId])
}

model WorkOrderMedia {
  id               String    @id @default(uuid())
  workOrderId      String
  mediaType        String
  storageProvider  String
  objectKey        String
  bucketName       String
  mimeType         String?
  originalFileName String?
  fileSizeBytes    Int?
  createdByUserId  String?
  createdAt        DateTime  @default(now())
  deletedAt        DateTime?
  deletedByUserId  String?

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([workOrderId, createdAt])
}

model WorkOrderEvent {
  id              String   @id @default(uuid())
  workOrderId     String
  eventType       String
  label           String
  metadata        Json?
  createdByUserId String?
  createdAt       DateTime @default(now())

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([workOrderId, createdAt])
}

model WorkOrderStatusHistory {
  id              String     @id @default(uuid())
  workOrderId     String
  fromStatus      JobStatus?
  toStatus        JobStatus
  changedByUserId String?
  changedAt       DateTime   @default(now())
  reasonCode      String?
  notes           String?
  source          String

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([workOrderId, changedAt])
}

model HotShotDetails {
  id                String    @id @default(uuid())
  workOrderId       String    @unique
  pickupName        String?
  pickupPhone       String?
  pickupAddress1    String
  pickupAddress2    String?
  pickupCity        String
  pickupState       String
  pickupPostalCode  String
  dropoffName       String?
  dropoffPhone      String?
  dropoffAddress1   String
  dropoffAddress2   String?
  dropoffCity       String
  dropoffState      String
  dropoffPostalCode String
  urgency           String    @default("normal")
  acceptedAt        DateTime?
  pickedUpAt        DateTime?
  deliveredAt       DateTime?

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
}

model WorkOrderAssignment {
  id             String   @id @default(uuid())
  workOrderId    String
  teamId         String?
  userId         String?
  assignmentType String
  isActive       Boolean  @default(true)
  assignedAt     DateTime @default(now())

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  team      Team?     @relation(fields: [teamId], references: [id], onDelete: SetNull)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workOrderId, isActive])
  @@index([userId, isActive])
  @@index([teamId, isActive])
}

model DispatchMessage {
  id       String  @id @default(uuid())
  title    String
  body     String
  priority String  @default("normal")
  isActive Boolean @default(true)

  targetScope       MessageTargetScope @default(all_active_field)
  targetRole        UserRole?
  targetUserId      String?
  targetWorkOrderId String?
  targetCompanyId   String?

  messageCategory         MessageCategory @default(general)
  requiresAcknowledgement Boolean         @default(false)

  createdByUserId String
  expiresAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdByUser   User                  @relation("DispatchMessageCreatedBy", fields: [createdByUserId], references: [id])
  targetUser      User?                 @relation("DispatchMessageTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)
  targetCompany   Company?              @relation("DispatchMessageTargetCompany", fields: [targetCompanyId], references: [id], onDelete: SetNull)
  targetWorkOrder WorkOrder?            @relation(fields: [targetWorkOrderId], references: [id], onDelete: SetNull)
  readReceipts    DispatchMessageRead[]

  @@index([targetScope])
  @@index([targetRole])
  @@index([targetUserId])
  @@index([targetWorkOrderId])
  @@index([targetCompanyId])
  @@index([messageCategory])
  @@index([priority, isActive, expiresAt])
}

model DispatchMessageRead {
  id                String    @id @default(uuid())
  dispatchMessageId String
  userId            String
  readAt            DateTime  @default(now())
  acknowledgedAt    DateTime?

  dispatchMessage DispatchMessage @relation(fields: [dispatchMessageId], references: [id], onDelete: Cascade)
  user            User            @relation(fields: [userId], references: [id])

  @@unique([dispatchMessageId, userId])
  @@index([userId])
}

model UserLocationLog {
  id        String   @id @default(uuid())
  userId    String
  latitude  Float
  longitude Float
  accuracy  Float?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model TeamMessage {
  id        String   @id @default(uuid())
  teamId    String?
  userId    String
  body      String
  createdAt DateTime @default(now())

  team Team? @relation(fields: [teamId], references: [id], onDelete: SetNull)
  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([teamId, createdAt])
}
